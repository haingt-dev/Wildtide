{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --name-only --diff-filter=M 2>/dev/null | grep '\\.gd$' | xargs -r gdformat 2>/dev/null || true",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "godot-dev@haint-marketplace": true
  }
}
