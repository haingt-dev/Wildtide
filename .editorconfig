root = true

[*]
charset = utf-8
indent_style = tab
indent_size = 4
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# GDScript — tabs (Godot convention)
[*.gd]
indent_style = tab
indent_size = 4

# Godot resource/scene files — managed by Godot, don't reformat
[*.{tres,tscn}]
insert_final_newline = false
trim_trailing_whitespace = false

# Godot project file
[project.godot]
insert_final_newline = false
trim_trailing_whitespace = false

# Shaders
[*.{gdshader,gdshaderinc}]
indent_style = tab
indent_size = 4

# Markdown — preserve trailing whitespace for line breaks
[*.md]
trim_trailing_whitespace = false

# JSON
[*.json]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Containerfiles
[Containerfile]
indent_style = tab
indent_size = 4
