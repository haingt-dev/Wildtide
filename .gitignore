# Godot 4.x
.godot/

# Godot export
/android/
*.apk
*.aab

# Export presets (may contain sensitive paths/credentials)
# Uncomment if you want to track export presets:
# !export_presets.cfg
export_presets.cfg

# Godot import files (auto-generated by editor)
# These are regenerated on project open — safe to ignore
*.import

# OS files
.DS_Store
Thumbs.db
Desktop.ini
*~

# IDE
*.swp
*.swo
.idea/

# Build artifacts
/build/
/export/

# Environment secrets (NEVER commit)
.env
.env.*
!.env.example
!.env.template

# API keys and credentials
config.json
credentials.json
credentials.*
secrets.*
*.key
*.pem

# Agent credentials
.agent/credentials.*
.agent/secrets.*

# GUT test output
.gut_editor_config.json
.gut_editor_shortcuts.cfg
